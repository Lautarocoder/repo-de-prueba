;=========================================================
; PIC16F887 - Teclado 3x3 + 4 displays multiplexados
; CON INTERRUPCIONES (IOC del Puerto B)
; Hardware idéntico al primer código:
;   Columnas -> RB0, RB1, RB2  (salidas)
;   Filas	-> RB4, RB5, RB6  (entradas con pull-up e IOC)
;   Display  -> PORTD segmentos, RC0-RC3 transistores
;=========================================================

    	LIST P=16F887
    	#include "p16f887.inc"

    	__CONFIG _CONFIG1, _FOSC_XT & _WDTE_OFF & _PWRTE_ON & _MCLRE_ON & _CP_OFF & _CPD_OFF & _BOREN_OFF & _IESO_OFF & _FCMEN_OFF & _LVP_OFF
    	__CONFIG _CONFIG2, _BOR40V & _WRT_OFF

;---------------- VARIABLES ----------------
W_TEMP  	EQU 0x70
STATUS_TEMP EQU 0x71
INDEX    	EQU 0x20  	; índice para display actual (0..3)
NUM0    	EQU 0x21  	; valores a mostrar en displays
NUM1    	EQU 0x22
NUM2    	EQU 0x23
NUM3    	EQU 0x24
INDEX_TECLADO EQU 0x25	; índice para guardar tecla en buffer circular
CONTADOR_TECLA EQU 0X26   ; valor de tecla detectada
; variables para delays reutilizando RAM no usada del segundo código
D1      	EQU 0x27  	; para PAUSA_CORTA
D2      	EQU 0x28
; 0x29, 0x30, 0x31, 0x32 ya no se necesitan pero no molestan

;---------------- RESET ----------------
    	ORG 0x0000
    	GOTO INICIO

;---------------- INTERRUPCION ----------------
    	ORG 0x0004
    	GOTO ISR

;---------------- INICIO ----------------
INICIO:
    	; Banco 1
    	BSF 	STATUS,RP0
    	BCF 	STATUS,RP1

    	CLRF	TRISD         	; RD0-RD7 salida (segmentos)
    	MOVLW   b'11110000'   	; RC0-RC3 salidas (transistores), RC4-RC7 entradas
    	MOVWF   TRISC
    	MOVLW   b'11111000'   	; RB0,RB1,RB2 salidas (columnas), RB4-RB6 entradas (filas), RB3,RB7 entradas sin uso
    	MOVWF   TRISB
    	MOVLW   b'11110000'   	; pull-ups en RB4-RB7 (solo RB4-RB6 conectadas al teclado)
    	MOVWF   WPUB
    	MOVLW   b'01110000'   	; Interrupción por cambio solo en RB4,RB5,RB6
    	MOVWF   IOCB

    	; Timer0: interno, prescaler 1:32, pull-ups PORTB activos
    	MOVLW   b'00000100'
    	MOVWF   OPTION_REG

    	; Banco 3: pines digitales
    	BSF 	STATUS,RP0
    	BSF 	STATUS,RP1
    	CLRF	ANSEL
    	CLRF	ANSELH

    	; Banco 0
    	BCF 	STATUS,RP0
    	BCF 	STATUS,RP1

    	CLRF	PORTD
    	CLRF	PORTC
    	CLRF	PORTB         	; todas las columnas en bajo inicialmente

    	CLRF	NUM0
    	CLRF	NUM1
    	CLRF	NUM2
    	CLRF	NUM3
    	CLRF	INDEX_TECLADO

    	; Inicializa Timer0 (mismo timing del primer código)
    	MOVLW   .100
    	MOVWF   TMR0

    	; Lectura inicial del puerto B para IOC
    	MOVF	PORTB,W

    	; Habilita interrupciones
    	BSF 	INTCON,RBIE
    	BSF 	INTCON,T0IE
    	BSF 	INTCON,GIE

    	CLRF	INDEX

;---------------- LOOP PRINCIPAL ----------------
LOOP:
    	GOTO	LOOP          	; espera interrupciones

;===============================================
;           	RUTINAS DE INTERRUPCION
;===============================================
ISR:
    	; Guardado de contexto
    	MOVWF   W_TEMP
    	SWAPF   STATUS,W
    	MOVWF   STATUS_TEMP

    	; Discriminación de interrupción
    	BTFSC   INTCON,RBIF
    	GOTO	ISR_TECLADO
    	BTFSC   INTCON,T0IF
    	GOTO	ISR_TMR0

    	GOTO	FIN_ISR

;-------- INTERRUPCION DE TIMER0 (Multiplexado) --------
ISR_TMR0:
    	MOVLW   .100
    	MOVWF   TMR0

    	; Apaga displays
    	CLRF	PORTC

    	; Obtiene dígito según INDEX y lo muestra en PORTD
    	MOVLW   NUM0
    	ADDWF   INDEX,W
    	MOVWF   FSR
    	MOVF	INDF,W
    	ANDLW   0x0F
    	CALL	TABLA_7SEG
    	MOVWF   PORTD

    	; Activa el transistor correspondiente
    	MOVF	INDEX,W
    	CALL	HABILITACION_DISPLAY
    	MOVWF   PORTC

    	; Siguiente display (0->1->2->3->0)
    	INCF	INDEX,F
    	MOVF	INDEX,W
    	XORLW   0x04
    	BTFSC   STATUS,Z
    	CLRF	INDEX

    	BCF 	INTCON,T0IF
    	GOTO	FIN_ISR

;-------- INTERRUPCION DE TECLADO (IOC) ---------
ISR_TECLADO:
    	; Antirrebote simple (pausa corta)
    	CALL	PAUSA_CORTA

    	; ----- Barrido 3x3 adaptado -----
    	; Columna 1 (RB0=0)
    	MOVLW   b'11111110'
    	MOVWF   PORTB
    	CALL	PAUSA_CORTA

    	MOVLW   0x01         	; valor de tecla inicial para columna 1
    	MOVWF   CONTADOR_TECLA
    	BTFSS   PORTB,4
    	GOTO	GUARDAR_TECLA
    	MOVLW   0x03
    	ADDWF   CONTADOR_TECLA,F   ; ahora 4
    	BTFSS   PORTB,5
    	GOTO	GUARDAR_TECLA
    	MOVLW   0x03
    	ADDWF   CONTADOR_TECLA,F   ; ahora 7
    	BTFSS   PORTB,6
    	GOTO	GUARDAR_TECLA

    	; Columna 2 (RB1=0)
    	MOVLW   b'11111101'
    	MOVWF   PORTB
    	CALL	PAUSA_CORTA

    	MOVLW   0x02
    	MOVWF   CONTADOR_TECLA
    	BTFSS   PORTB,4
    	GOTO	GUARDAR_TECLA
    	MOVLW   0x03
    	ADDWF   CONTADOR_TECLA,F   ; 5
    	BTFSS   PORTB,5
    	GOTO	GUARDAR_TECLA
    	MOVLW   0x03
    	ADDWF   CONTADOR_TECLA,F   ; 8
    	BTFSS   PORTB,6
    	GOTO	GUARDAR_TECLA

    	; Columna 3 (RB2=0)
    	MOVLW   b'11111011'
    	MOVWF   PORTB
    	CALL	PAUSA_CORTA

    	MOVLW   0x03
    	MOVWF   CONTADOR_TECLA
    	BTFSS   PORTB,4
    	GOTO	GUARDAR_TECLA
    	MOVLW   0x03
    	ADDWF   CONTADOR_TECLA,F   ; 6
    	BTFSS   PORTB,5
    	GOTO	GUARDAR_TECLA
    	MOVLW   0x03
    	ADDWF   CONTADOR_TECLA,F   ; 9
    	BTFSS   PORTB,6
    	GOTO	GUARDAR_TECLA

    	; Si no se detectó ninguna tecla, salir
    	GOTO	FIN_ISR_TECLADO

GUARDAR_TECLA:
    	; Guardar CONTADOR_TECLA en el buffer circular (NUM0..NUM3)
    	MOVLW   NUM0
    	ADDWF   INDEX_TECLADO,W
    	MOVWF   FSR
    	MOVF	CONTADOR_TECLA,W
    	MOVWF   INDF

    	; Avanzar índice circular (0..3)
    	INCF	INDEX_TECLADO,F
    	MOVF	INDEX_TECLADO,W
    	XORLW   0x04
    	BTFSC   STATUS,Z
    	CLRF	INDEX_TECLADO

FIN_ISR_TECLADO:
    	; Deja PORTB listo para detectar la próxima tecla
    	CLRF	PORTB
    	MOVF	PORTB,W      	; lectura para actualizar condición IOC
    	BCF 	INTCON,RBIF
    	; (no se limpia T0IF aquí, ya se hizo en su bloque)

FIN_ISR:
    	; Recuperación de contexto
    	SWAPF   STATUS_TEMP,W
    	MOVWF   STATUS
    	SWAPF   W_TEMP,F
    	SWAPF   W_TEMP,W
    	RETFIE

;===============================================
;           	TABLAS Y SUBRUTINAS
;===============================================

;--- Tabla 7 segmentos cátodo común ---
TABLA_7SEG:
    	ADDWF   PCL,F
    	RETLW   B'00111111' ; 0
    	RETLW   B'00000110' ; 1
    	RETLW   B'01011011' ; 2
    	RETLW   B'01001111' ; 3
    	RETLW   B'01100110' ; 4
    	RETLW   B'01101101' ; 5
    	RETLW   B'01111101' ; 6
    	RETLW   B'00000111' ; 7
    	RETLW   B'01111111' ; 8
    	RETLW   B'01101111' ; 9
    	RETLW   B'01110111' ; A
    	RETLW   B'01111100' ; b
    	RETLW   B'00111001' ; C
    	RETLW   B'01011110' ; d
    	RETLW   B'01111001' ; E
    	RETLW   B'01110001' ; F

;--- Activar transistor de display según índice (0..3) ---
HABILITACION_DISPLAY:
    	ADDWF   PCL,F
    	RETLW   B'00000001' ; RC0
    	RETLW   B'00000010' ; RC1
    	RETLW   B'00000100' ; RC2
    	RETLW   B'00001000' ; RC3

;--- Pausa corta para estabilidad del teclado ---
PAUSA_CORTA:
    	MOVLW   .20
    	MOVWF   D1
PC1:
    	DECFSZ  D1,F
    	GOTO	PC1
    	RETURN

    	END

